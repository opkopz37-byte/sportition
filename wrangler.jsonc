{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "sportition-nextjs",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      // 반드시 위의 "name"과 동일해야 함 (열려 있으면 self-reference 배포 실패)
      "service": "sportition-nextjs"
    }
  ],
  "r2_buckets": [],
  "images": {
    "binding": "IMAGES"
  }
}
