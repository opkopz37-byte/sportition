# ===========================================
# Sportition — Supabase 환경 변수
# ===========================================
# 사용법:
#   1) 이 파일을 복사해서 `.env.local` 로 저장하세요.
#      cp .env.example .env.local
#   2) 아래 값을 Supabase 대시보드(Settings → API)에서 복사해 넣으세요.
#   3) 개발 서버를 다시 실행하세요: npm run dev
#
# ⚠️ `.env.local` 은 Git에 커밋하지 마세요.

# 프로젝트 URL (대시보드 DATA API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# 클라이언트용 키 (대시보드의 Publishable key — 예: sb_publishable_... 또는 기존 anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------
# 서버 전용 Secret key (대시보드 Secret keys — 예: sb_secret_...)
# API Route / Server Actions 등에서만 사용. 브라우저·NEXT_PUBLIC에 넣지 마세요.
# -------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
