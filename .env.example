# ===========================================
# Sportition — Supabase 환경 변수
# ===========================================
# 사용법:
#   1) 이 파일을 복사해서 `.env.local` 로 저장하세요.
#      cp .env.example .env.local
#   2) 아래 값을 Supabase 대시보드(Settings → API)에서 복사해 넣으세요.
#   3) 개발 서버를 다시 실행하세요: npm run dev
#
# ⚠️ `.env.local` 은 Git에 커밋하지 마세요.

# -------------------------------------------
# Next.js 개발 서버 (선택)
# macOS 등에서 Watchpack EMFILE 오류로 빈 화면·500·번들(layout.css/main-app.js) 404가 나면
# 1) 터미널에서 개발 서버를 끄고: npm run dev:clean  ( .next 삭제 후 재시작 )
# 2) 같은 증상이 반복되면 터미널에서 한 번: ulimit -n 10240  그 다음 npm run dev
#    (npm run dev 는 scripts/dev.sh 에서 darwin 일 때 ulimit 을 시도합니다)
# 3) 그래도 안 되면 아래 한 줄을 .env.local 에 넣고 재시작 (next.config 에서 darwin 은 기본 폴링)
# -------------------------------------------
# NEXT_WEBPACK_POLLING=1

# 프로젝트 URL (대시보드 DATA API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# 클라이언트용 키 (대시보드의 Publishable key — 예: sb_publishable_... 또는 기존 anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------
# 서버 전용 Secret key (대시보드 Secret keys — 예: sb_secret_...)
# API Route / Server Actions 등에서만 사용. 브라우저·NEXT_PUBLIC에 넣지 마세요.
# -------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
